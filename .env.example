# Server
PORT=8080
DATABASE_PATH=postflow.db
DATA_DIR=data

# Worker
WORKER_INTERVAL_SECONDS=30
RETRY_BACKOFF_SECONDS=30
DEFAULT_MAX_RETRIES=3

# API/UI security
RATE_LIMIT_RPM=120
API_TOKEN=
UI_BASIC_USER=
UI_BASIC_PASS=

# Logging
LOG_LEVEL=info

# PostFlow driver: mock | live
# ("x" is still accepted as a backward-compatible alias)
POSTFLOW_DRIVER=mock

# Credentials encryption (required)
# Generate with: openssl rand -base64 32
POSTFLOW_MASTER_KEY=

# Public base URL for OAuth callbacks and signed media URLs.
# In production this must be your public HTTPS domain (not localhost).
PUBLIC_BASE_URL=http://localhost:8080

# LinkedIn OAuth app
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Meta OAuth app (Facebook/Instagram)
META_APP_ID=
META_APP_SECRET=

# X app credentials
X_API_BASE_URL=https://api.x.com
X_UPLOAD_BASE_URL=https://upload.twitter.com
X_AUTH_BASE_URL=https://x.com
X_TOKEN_URL=https://api.x.com/2/oauth2/token
X_CLIENT_ID=
X_CLIENT_SECRET=
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
