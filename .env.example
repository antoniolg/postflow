# Server
PORT=8080
DATABASE_PATH=publisher.db
DATA_DIR=data

# Worker
WORKER_INTERVAL_SECONDS=30
RETRY_BACKOFF_SECONDS=30
DEFAULT_MAX_RETRIES=3

# API/UI security
RATE_LIMIT_RPM=120
API_TOKEN=
UI_BASIC_USER=
UI_BASIC_PASS=

# Logging
LOG_LEVEL=info

# Publisher driver: mock | x
PUBLISHER_DRIVER=mock

# X/Twitter API credentials (required only when PUBLISHER_DRIVER=x)
X_API_BASE_URL=https://api.twitter.com
X_UPLOAD_BASE_URL=https://upload.twitter.com
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
