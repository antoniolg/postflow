# Server
PORT=8080
DATABASE_PATH=publisher.db
DATA_DIR=data

# Worker
WORKER_INTERVAL_SECONDS=30
RETRY_BACKOFF_SECONDS=30
DEFAULT_MAX_RETRIES=3

# API/UI security
RATE_LIMIT_RPM=120
API_TOKEN=
UI_BASIC_USER=
UI_BASIC_PASS=

# Logging
LOG_LEVEL=info

# Publisher driver: mock | x
PUBLISHER_DRIVER=mock

# Credentials encryption (required)
# Generate with: openssl rand -base64 32
PUBLISHER_MASTER_KEY=

# Public base URL for OAuth callbacks
PUBLIC_BASE_URL=http://localhost:8080

# LinkedIn OAuth app
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Meta OAuth app (Facebook/Instagram)
META_APP_ID=
META_APP_SECRET=

# X/Twitter API credentials (needed for static bootstrap x-default when PUBLISHER_DRIVER=x)
X_API_BASE_URL=https://api.twitter.com
X_UPLOAD_BASE_URL=https://upload.twitter.com
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
